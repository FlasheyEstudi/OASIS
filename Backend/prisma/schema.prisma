generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String          @id @default(cuid())
  email                String          @unique
  password             String
  name                 String
  phone                String?
  role                 String
  avatarUrl            String?
  isActive             Boolean         @default(true)
  isDemoUser           Boolean         @default(false)
  emailVerified        Boolean         @default(false)
  phoneVerified        Boolean         @default(false)
  refreshToken         String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  fcmToken             String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  auditLogs            AuditLog[]
  clinicAdmin          ClinicAdmin?
  deliveryPerson       DeliveryPerson?
  doctor               Doctor?
  sentMessages         Message[]       @relation("SentMessages")
  notifications        Notification[]
  patient              Patient?
  pharmacyAdmin        PharmacyAdmin?
  pharmacyStaff        PharmacyStaff?
  receptionist         Receptionist?
}

model ClinicAdmin {
  id        String   @id @default(cuid())
  userId    String   @unique
  clinicId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Clinic {
  id             String         @id @default(cuid())
  name           String
  description    String?
  logoUrl        String?
  phone          String?
  email          String?
  website        String?
  parentClinicId String?
  address        String?
  city           String?
  department     String?
  latitude       Float?
  longitude      Float?
  settings       String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  appointments   Appointment[]
  auditLogs      AuditLog[]
  chats          Chat[]
  parentClinic   Clinic?        @relation("ClinicBranches", fields: [parentClinicId], references: [id])
  branches       Clinic[]       @relation("ClinicBranches")
  admins         ClinicAdmin[]
  doctors        Doctor[]
  invoices       Invoice[]
  receptionists  Receptionist[]
  services       Service[]
}

model Receptionist {
  id        String   @id @default(cuid())
  userId    String   @unique
  clinicId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Doctor {
  id                   String          @id @default(cuid())
  userId               String          @unique
  clinicId             String
  specialty            String
  licenseNumber        String          @unique
  digitalSignatureCert String?
  schedule             String?
  biography            String?
  consultationFee      Float           @default(0)
  rating               Float           @default(0)
  totalReviews         Int             @default(0)
  isActive             Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  appointments         Appointment[]
  chats                Chat[]
  clinic               Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctorPatients       DoctorPatient[]
  prescriptions        Prescription[]
}

model Patient {
  id                    String          @id @default(cuid())
  userId                String          @unique
  dateOfBirth           DateTime?
  gender                String?
  bloodType             String?
  allergies             String?
  chronicConditions     String?
  emergencyContact      String?
  familyGroupId         String?
  insuranceProvider     String?
  insurancePolicyNumber String?
  address               String?
  city                  String?
  department            String?
  latitude              Float?
  longitude             Float?
  loyaltyPoints         Int             @default(0)
  loyaltyLevel          String          @default("bronce")
  isActive              Boolean         @default(true)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  appointments          Appointment[]
  chats                 Chat[]
  doctorPatients        DoctorPatient[]
  familyMembers         FamilyMember[]
  insurances            Insurance[]
  orders                Order[]
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescriptions         Prescription[]
  refillRequests        RefillRequest[]
  reviews               Review[]
}

model FamilyMember {
  id                    String    @id @default(cuid())
  patientId             String
  name                  String
  relationship          String
  dateOfBirth           DateTime?
  gender                String?
  bloodType             String?
  allergies             String?
  chronicConditions     String?
  insuranceProvider     String?
  insurancePolicyNumber String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  patient               Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model DoctorPatient {
  id         String   @id @default(cuid())
  doctorId   String
  patientId  String
  assignedAt DateTime @default(now())
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor     Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, patientId])
}

model Pharmacy {
  id               String           @id @default(cuid())
  name             String
  description      String?
  logoUrl          String?
  phone            String?
  email            String?
  website          String?
  parentPharmacyId String?
  address          String?
  city             String?
  department       String?
  latitude         Float?
  longitude        Float?
  deliverySettings String?
  paymentMethods   String?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  chats            Chat[]
  inventoryBatches InventoryBatch[]
  orders           Order[]
  parentPharmacy   Pharmacy?        @relation("PharmacyBranches", fields: [parentPharmacyId], references: [id])
  branches         Pharmacy[]       @relation("PharmacyBranches")
  admins           PharmacyAdmin[]
  staff            PharmacyStaff[]
  promotions       Promotion[]
  purchaseOrders   PurchaseOrder[]
  suppliers        Supplier[]
}

model PharmacyAdmin {
  id         String   @id @default(cuid())
  userId     String   @unique
  pharmacyId String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PharmacyStaff {
  id         String   @id @default(cuid())
  userId     String   @unique
  pharmacyId String
  role       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Medication {
  id                   String              @id @default(cuid())
  name                 String
  genericName          String?
  brand                String?
  description          String?
  dosageForm           String?
  strength             String?
  manufacturer         String?
  requiresPrescription Boolean             @default(false)
  controlledSubstance  Boolean             @default(false)
  controlledLevel      String?
  interactionGroups    String?
  sideEffects          String?
  contraindications    String?
  category             String?
  imageUrl             String?
  isActive             Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  inventoryBatches     InventoryBatch[]
  orderItems           OrderItem[]
  prescriptionItems    PrescriptionItem[]
  promotionItems       PromotionItem[]
  purchaseOrderItems   PurchaseOrderItem[]
}

model InventoryBatch {
  id            String     @id @default(cuid())
  pharmacyId    String
  medicationId  String
  batchNumber   String
  quantity      Int        @default(0)
  expiryDate    DateTime
  costPrice     Float      @default(0)
  sellingPrice  Float      @default(0)
  supplierId    String?
  minStockAlert Int        @default(10)
  maxStock      Int        @default(1000)
  location      String?
  isActive      Boolean    @default(true)
  receivedAt    DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  supplier      Supplier?  @relation(fields: [supplierId], references: [id])
  medication    Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  pharmacy      Pharmacy   @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@unique([pharmacyId, medicationId, batchNumber])
}

model Supplier {
  id               String           @id @default(cuid())
  pharmacyId       String
  name             String
  contactName      String?
  phone            String?
  email            String?
  address          String?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  inventoryBatches InventoryBatch[]
  purchaseOrders   PurchaseOrder[]
  pharmacy         Pharmacy         @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  pharmacyId   String
  supplierId   String
  status       String              @default("pending")
  totalAmount  Float               @default(0)
  notes        String?
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  receivedDate DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  supplier     Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  pharmacy     Pharmacy            @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  items        PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  medicationId     String
  quantity         Int
  unitCost         Float
  totalCost        Float
  receivedQuantity Int           @default(0)
  batchNumber      String?
  expiryDate       DateTime?
  createdAt        DateTime      @default(now())
  medication       Medication    @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model Prescription {
  id               String             @id @default(cuid())
  doctorId         String
  patientId        String
  familyMemberId   String?
  date             DateTime           @default(now())
  diagnosis        String?
  notes            String?
  digitalSignature String?
  isControlled     Boolean            @default(false)
  validUntil       DateTime?
  refillsRemaining Int                @default(0)
  verificationCode String?            @unique
  status           String             @default("active")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  patient          Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor           Doctor             @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  items            PrescriptionItem[]
  refillRequests   RefillRequest[]
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  medicationId   String
  dosage         String
  duration       String?
  quantity       Int
  instructions   String?
  isControlled   Boolean      @default(false)
  createdAt      DateTime     @default(now())
  medication     Medication   @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

model RefillRequest {
  id             String       @id @default(cuid())
  prescriptionId String
  patientId      String
  status         String       @default("pending")
  doctorNotes    String?
  requestedAt    DateTime     @default(now())
  processedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

model Service {
  id           String        @id @default(cuid())
  clinicId     String
  name         String
  description  String?
  duration     Int           @default(30)
  price        Float         @default(0)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

model Appointment {
  id                 String   @id @default(cuid())
  clinicId           String
  doctorId           String
  patientId          String
  familyMemberId     String?
  serviceId          String?
  date               DateTime
  startTime          String
  endTime            String
  status             String   @default("scheduled")
  type               String   @default("presencial")
  teleconsultLink    String?
  notes              String?
  cancellationReason String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  service            Service? @relation(fields: [serviceId], references: [id])
  patient            Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor             Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic             Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  invoice            Invoice?
}

model Order {
  id                     String         @id @default(cuid())
  patientId              String
  pharmacyId             String
  prescriptionId         String?
  status                 String         @default("pending")
  paymentMethod          String         @default("cash")
  paymentStatus          String         @default("pending")
  insuranceClaimId       String?
  subtotal               Float          @default(0)
  deliveryFee            Float          @default(0)
  tipAmount              Float          @default(0)
  totalAmount            Float          @default(0)
  deliveryType           String         @default("delivery")
  deliveryAddress        String?
  deliveryLatitude       Float?
  deliveryLongitude      Float?
  deliveryNotes          String?
  failedDeliveryAttempts Int            @default(0)
  estimatedDeliveryTime  String?
  loyaltyPointsEarned    Int            @default(0)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  delivery               Delivery?
  invoice                Invoice?
  pharmacy               Pharmacy       @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  patient                Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  items                  OrderItem[]
  returnRequest          ReturnRequest?
}

model OrderItem {
  id                   String     @id @default(cuid())
  orderId              String
  medicationId         String
  quantity             Int
  unitPrice            Float
  totalPrice           Float
  batchId              String?
  requiresPrescription Boolean    @default(false)
  isControlled         Boolean    @default(false)
  createdAt            DateTime   @default(now())
  medication           Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  order                Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model DeliveryPerson {
  id                   String     @id @default(cuid())
  userId               String     @unique
  vehicleType          String?
  plateNumber          String?
  availabilitySchedule String?
  zones                String?
  rating               Float      @default(0)
  totalReviews         Int        @default(0)
  isVerified           Boolean    @default(false)
  idDocument           String?
  earningsBalance      Float      @default(0)
  isActive             Boolean    @default(true)
  isAvailable          Boolean    @default(false)
  isInternal           Boolean    @default(false)
  pharmacyId           String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  deliveries           Delivery[]
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Delivery {
  id                  String         @id @default(cuid())
  orderId             String         @unique
  deliveryPersonId    String
  status              String         @default("assigned")
  routeOptimized      String?
  proofPhotoUrl       String?
  signatureUrl        String?
  cashCollectedAmount Float?
  pickupTime          DateTime?
  deliveryTime        DateTime?
  estimatedArrival    DateTime?
  failedReason        String?
  notes               String?
  currentLat          Float?
  currentLng          Float?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deliveryPerson      DeliveryPerson @relation(fields: [deliveryPersonId], references: [id], onDelete: Cascade)
  order               Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Chat {
  id            String    @id @default(cuid())
  patientId     String
  doctorId      String?
  clinicId      String?
  pharmacyId    String?
  type          String    @default("patient_doctor")
  status        String    @default("active")
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  pharmacy      Pharmacy? @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  clinic        Clinic?   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor        Doctor?   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  messages      Message[]
}

model Message {
  id         String   @id @default(cuid())
  chatId     String
  senderId   String
  message    String
  attachment String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

model Invoice {
  id              String          @id @default(cuid())
  appointmentId   String?         @unique
  orderId         String?         @unique
  clinicId        String?
  pharmacyId      String?
  patientId       String
  invoiceNumber   String          @unique
  type            String          @default("consultation")
  subtotal        Float           @default(0)
  tax             Float           @default(0)
  discount        Float           @default(0)
  total           Float           @default(0)
  paymentMethod   String          @default("cash")
  paymentStatus   String          @default("pending")
  insuranceAmount Float?
  copayAmount     Float?
  pdfUrl          String?
  notes           String?
  issuedAt        DateTime        @default(now())
  dueDate         DateTime?
  paidAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  clinic          Clinic?         @relation(fields: [clinicId], references: [id])
  order           Order?          @relation(fields: [orderId], references: [id])
  appointment     Appointment?    @relation(fields: [appointmentId], references: [id])
  returnRequest   ReturnRequest[]
}

model ReturnRequest {
  id            String    @id @default(cuid())
  orderId       String    @unique
  patientId     String
  reason        String
  status        String    @default("pending")
  returnToStock Boolean   @default(false)
  refundAmount  Float     @default(0)
  notes         String?
  invoiceId     String?
  processedById String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  invoice       Invoice?  @relation(fields: [invoiceId], references: [id])
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Review {
  id         String   @id @default(cuid())
  patientId  String
  targetType String
  targetId   String
  rating     Int
  comment    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Insurance {
  id              String    @id @default(cuid())
  patientId       String
  provider        String
  policyNumber    String
  coverageDetails String?
  copayPercentage Float     @default(0)
  isActive        Boolean   @default(true)
  validUntil      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  patient         Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Promotion {
  id          String          @id @default(cuid())
  pharmacyId  String
  name        String
  description String?
  type        String
  value       Float
  code        String?         @unique
  minPurchase Float           @default(0)
  maxDiscount Float?
  startDate   DateTime
  endDate     DateTime
  usageLimit  Int?
  usageCount  Int             @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  pharmacy    Pharmacy        @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  items       PromotionItem[]
}

model PromotionItem {
  id           String      @id @default(cuid())
  promotionId  String
  medicationId String?
  category     String?
  createdAt    DateTime    @default(now())
  medication   Medication? @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  promotion    Promotion   @relation(fields: [promotionId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  data      String?
  isRead    Boolean   @default(false)
  sentVia   String    @default("push")
  sentAt    DateTime  @default(now())
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  clinicId  String?
  action    String
  entity    String
  entityId  String?
  oldValues String?
  newValues String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  clinic    Clinic?  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
}

model PaymentTransaction {
  id              String    @id @default(cuid())
  invoiceId       String?
  orderId         String?
  amount          Float
  currency        String    @default("NIO")
  paymentMethod   String
  status          String    @default("pending")
  gatewayResponse String?
  transactionRef  String?   @unique
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
